{
  "name": "charliets",
  "version": "0.1.7",
  "private": true,
  "dependencies": {
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.9.4",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.4.19"
  },
  "scripts": {
    "start": "react-app-rewired start",
    "build": "cross-env CI=false react-app-rewired build",
    "test": "react-app-rewired test --passWithNoTests",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "react/prop-types": "off",
      "no-empty": [
        "error",
        {
          "allowEmptyCatch": true
        }
      ],
      "no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_"
        }
      ],
      "no-useless-catch": "off"
    }
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "path-browserify": "^1.0.1",
    "prettier": "^3.2.5",
    "react-app-rewired": "^2.2.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
